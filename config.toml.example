# ─── Kubuno Keestore — Configuration ─────────────────────────────────────────
# Copiez ce fichier en config.toml et adaptez les valeurs.
# Les variables d'environnement préfixées KKS__ surchargent ce fichier.
# Exemple : KKS__SERVER__PORT=3115

[server]
host = "127.0.0.1"
port = 3114

[core]
url             = "http://127.0.0.1:8080"
internal_secret = "change_me"

# ── Base de données ───────────────────────────────────────────────────────────
# Les paramètres sont injectés par le superviseur Kubuno via variables d'env.
# Pour un démarrage hors superviseur, exporter manuellement :
#   KUBUNO_DB_HOST, KUBUNO_DB_PORT, KUBUNO_DB_USER, KUBUNO_DB_PASSWORD, KUBUNO_DB_NAME

[storage]
backend    = "local"
local_path = "/var/lib/kubuno/modules/keestore/data"
temp_path  = "/var/lib/kubuno/modules/keestore/temp"
# Développement local :
# local_path = "./data/vaults"
# temp_path  = "./data/temp"

[keestore]
# Taille maximale d'un fichier .kdbx (en bytes). Défaut : 50 Mo
max_kdbx_size_bytes = 52428800

[hibp]
api_url = "https://api.pwnedpasswords.com/range"

[logging]
level  = "info"
format = "pretty"
